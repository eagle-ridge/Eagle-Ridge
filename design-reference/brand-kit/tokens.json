{
  "$brand": "Eagle Ridge",
  "$description": "Design tokens for eagleridge.io. Default theme is 'parchment'. Hex values are the Parchment theme; alternates under themes.*.",
  "$version": "1.0.0",
  "color": {
    "bg":       { "value": "#F6F2EA", "comment": "page background — warm paper" },
    "paper":    { "value": "#FAF7F0", "comment": "raised surfaces, cards" },
    "ink":      { "value": "#1A1614", "comment": "primary text, headlines" },
    "ink-soft": { "value": "#44372F", "comment": "body copy, secondary text" },
    "mute":     { "value": "#8B7D6E", "comment": "captions, labels, meta" },
    "rule":     { "value": "#D9D0BF", "comment": "hairlines, borders, dividers" },
    "accent":   { "value": "#4A2F22", "comment": "deep umber — brand primary" },
    "gold":     { "value": "#B08A4E", "comment": "gold — emphasis only, sparingly" }
  },
  "themes": {
    "parchment": {
      "bg": "#F6F2EA", "paper": "#FAF7F0", "ink": "#1A1614", "ink-soft": "#44372F",
      "mute": "#8B7D6E", "rule": "#D9D0BF", "accent": "#4A2F22", "gold": "#B08A4E"
    },
    "slate": {
      "bg": "#E5E9ED", "paper": "#EEF1F4", "ink": "#14202B", "ink-soft": "#34475A",
      "mute": "#7A8898", "rule": "#C4CCD3", "accent": "#2D5F78", "gold": "#8B7340"
    },
    "bone": {
      "bg": "#F3EFE8", "paper": "#FFFFFF", "ink": "#15110E", "ink-soft": "#3D352D",
      "mute": "#8E8479", "rule": "#D6CFC4", "accent": "#B14E26", "gold": "#B14E26"
    },
    "onyx": {
      "bg": "#14110C", "paper": "#1D1913", "ink": "#EDE4D2", "ink-soft": "#C9BFA9",
      "mute": "#7E7361", "rule": "rgba(237,228,210,0.16)", "accent": "#C29554", "gold": "#C29554"
    }
  },
  "font": {
    "serif":   { "value": "\"Newsreader\", Georgia, serif", "comment": "display / editorial headlines", "google": "Newsreader:ital,opsz,wght@0,6..72,300..700;1,6..72,300..500" },
    "sans":    { "value": "\"IBM Plex Sans\", system-ui, sans-serif", "comment": "UI / body", "google": "IBM+Plex+Sans:wght@300;400;500;600;700" },
    "mono":    { "value": "\"IBM Plex Mono\", ui-monospace, monospace", "comment": "labels / data", "google": "IBM+Plex+Mono:wght@400;500" },
    "grotesk": { "value": "\"Bricolage Grotesque\", sans-serif", "comment": "alternate display voice (modernist)", "google": "Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700" }
  },
  "fontSize": {
    "display": { "value": "clamp(2.75rem, 6vw, 5rem)",    "family": "serif" },
    "h1":      { "value": "clamp(2.25rem, 4.5vw, 3.5rem)", "family": "serif" },
    "h2":      { "value": "clamp(1.75rem, 3vw, 2.5rem)",   "family": "serif" },
    "h3":      { "value": "1.5rem",                         "family": "serif" },
    "lede":    { "value": "clamp(1.125rem, 1.6vw, 1.375rem)", "family": "sans", "weight": 300 },
    "body":    { "value": "1.0625rem", "family": "sans", "weight": 400 },
    "small":   { "value": "0.9375rem", "family": "sans" },
    "eyebrow": { "value": "0.8125rem", "family": "sans", "weight": 500, "transform": "uppercase", "tracking": "0.22em" }
  },
  "letterSpacing": {
    "display": "-0.028em",
    "tight":   "-0.015em",
    "eyebrow":  "0.22em"
  },
  "lineHeight": {
    "tight": 1.06,
    "body":  1.55
  },
  "space": {
    "1": "0.5rem", "2": "1rem", "3": "1.5rem", "4": "2rem",
    "5": "3rem", "6": "4.5rem", "7": "7rem"
  },
  "radius": {
    "sm": "2px", "md": "4px", "lg": "8px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(26,22,20,0.05)",
    "md": "0 8px 28px rgba(26,22,20,0.08)"
  },
  "layout": {
    "maxWidth": "1200px",
    "gutter": "clamp(1.25rem, 5vw, 5rem)"
  },
  "asset": {
    "logo": { "path": "assets/eagle-ridge-mark.png", "comment": "geometric eagle-head mark, transparent PNG 300x300" }
  }
}
