  }
  .manifesto h2 .pilcrow{color:var(--accent);font-style:normal;margin-right:12px;font-size:24px}
  .manifesto p{margin-bottom:24px}
  .manifesto p em{font-style:italic}
  .manifesto .small{font-size:15px;color:var(--ink-soft)}
  .manifesto a{color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(74,47,34,.35)}
  .manifesto a:hover{border-bottom-color:var(--accent)}
  .manifesto a:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:2px}

  /* pull quote */
  .manifesto .pull{
    margin:64px auto;max-width:540px;text-align:center;
    padding:36px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  }
