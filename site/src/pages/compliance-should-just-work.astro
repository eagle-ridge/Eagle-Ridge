  <script is:inline>
  /* ---------- Fig. 2: Accretion strata ---------- */
  (function(){
    const strata = [
      {yr:"1844", name:"Statutory audit", note:"Railway mania — shareholders vs. their own directors"},
      {yr:"1934", name:"SEC · audited statements", note:"The crash of 1929"},
      {yr:"1992", name:"SAS 70", note:"Outsourced computing — who checks the service org?"},
      {yr:"2002", name:"Sarbanes-Oxley", note:"Enron · WorldCom ($11B inflated)"},
      {yr:"2011", name:"SOC 2", note:"The cloud era — five Trust Services Criteria"},
      {yr:"2015", name:"NIST 800-171", note:"CUI exfiltration by adversaries"},
      {yr:"2025", name:"CMMC", note:"Self-attestation failed — POA&Ms dated 2099"}
    ];
    const g = document.getElementById('strata');
    if(!g){ console.warn('[fig2] #strata missing — figure not initialized'); return; }
    const ns = "http://www.w3.org/2000/svg";
    const baseY = 290, layerH = 30, x0 = 40, xMax = 680;
    strata.forEach((s,i)=>{
      const y = baseY - (i+1)*layerH;
      const x = x0 + i*48;
      const grp = document.createElementNS(ns,'g');
      grp.style.cursor='pointer';
      const r = document.createElementNS(ns,'rect');
      r.setAttribute('x',x); r.setAttribute('y',y);
      r.setAttribute('width',xMax-x); r.setAttribute('height',layerH-4);
      r.setAttribute('fill', i%2 ? 'rgba(43,35,22,.05)' : 'rgba(74,47,34,.06)');
      r.setAttribute('stroke','var(--line)'); r.setAttribute('stroke-width','0.9');
      const t = document.createElementNS(ns,'text');
      t.setAttribute('x',x+12); t.setAttribute('y',y+18);
      t.setAttribute('class','t-mono'); t.setAttribute('font-size','10.5');
      t.textContent = s.yr+" · "+s.name;
      const note = document.createElementNS(ns,'text');
      note.setAttribute('x',xMax-8); note.setAttribute('y',y+18);
      note.setAttribute('text-anchor','end');
      note.setAttribute('class','t-small'); note.setAttribute('font-size','11');
      note.setAttribute('fill','var(--accent)');
      note.style.opacity='0'; note.style.transition='opacity .25s';
      note.textContent = s.note;
      grp.addEventListener('mouseenter',()=>{note.style.opacity='1'; r.setAttribute('fill','rgba(74,47,34,.13)')});
      grp.addEventListener('mouseleave',()=>{note.style.opacity='0'; r.setAttribute('fill', i%2 ? 'rgba(43,35,22,.05)' : 'rgba(74,47,34,.06)')});
      grp.addEventListener('click',()=>{const v=note.style.opacity==='1';note.style.opacity=v?'0':'1'});
      grp.appendChild(r); grp.appendChild(t); grp.appendChild(note);
      g.appendChild(grp);
    });
  })();

  /* ---------- Fig. 3: Regressive tax slider ---------- */
  (function(){
    const slider = document.getElementById('sizeSlider');
    const readout = document.getElementById('sizeReadout');
    const dot = document.getElementById('taxDot');
    const drop = document.getElementById('taxDrop');
    const val = document.getElementById('taxValue');
    const curve = document.getElementById('taxCurve');
    if(!slider || !readout || !dot || !drop || !val || !curve){ console.warn('[fig3] missing element — figure not initialized'); return; }
    const FIXED = 105000;
    const x0=60, x1=670, y0=250, yTop=40;
    const emp = t => Math.round(10*Math.pow(200, t));
    const costPer = n => FIXED/n;
    const maxCost = costPer(10);
    const yFor = c => y0 - (Math.log10(c)-Math.log10(costPer(2000)))/(Math.log10(maxCost)-Math.log10(costPer(2000)))*(y0-yTop);
    let d='';
    for(let i=0;i<=100;i++){
      const t=i/100, x=x0+(x1-x0)*t, y=yFor(costPer(emp(t)));
      d += (i? ' L':'M')+x.toFixed(1)+' '+y.toFixed(1);
    }
    curve.setAttribute('d',d);
    function update(){
      const t = slider.value/100;
      const n = emp(t), c = costPer(n);
      const x = x0+(x1-x0)*t, y = yFor(c);
      dot.setAttribute('cx',x); dot.setAttribute('cy',y);
      drop.setAttribute('x1',x); drop.setAttribute('x2',x); drop.setAttribute('y1',y);
      val.setAttribute('x',x); val.setAttribute('y',y-14);
      val.textContent = '$'+Math.round(c).toLocaleString()+' / employee';
      readout.innerHTML = '<b>'+n.toLocaleString()+'</b> employees';
    }
    slider.addEventListener('input',update);
    update();
  })();

  /* ---------- Fig. 4: Snapshot vs Live Feed ---------- */
  (function(){
    const snapBtn=document.getElementById('modeSnap'),
          liveBtn=document.getElementById('modeLive'),
          runBtn=document.getElementById('runBtn'),
          line=document.getElementById('postureLine'),
          dot=document.getElementById('postureDot'),
          ticksG=document.getElementById('auditTicks'),
          midLabel=document.getElementById('midLabel');
    if(!snapBtn || !liveBtn || !runBtn || !line || !dot || !ticksG || !midLabel){ console.warn('[fig4] missing element — figure not initialized'); return; }
    const ns="http://www.w3.org/2000/svg";
    let mode='snap', anim=null;
    const x0=40,x1=680,yReq=80,yLow=230;
    function drawTicks(){
      ticksG.innerHTML='';
      const xs = mode==='snap' ? [x0,x1] : [];
      xs.forEach(x=>{
        const l=document.createElementNS(ns,'line');
        l.setAttribute('x1',x);l.setAttribute('x2',x);
        l.setAttribute('y1',70);l.setAttribute('y2',260);
        l.setAttribute('stroke','var(--accent)');l.setAttribute('stroke-width','1');
        l.setAttribute('stroke-dasharray','3 4');
        ticksG.appendChild(l);
        const c=document.createElementNS(ns,'circle');
        c.setAttribute('cx',x);c.setAttribute('cy',yReq);c.setAttribute('r','4');
        c.setAttribute('fill','var(--accent)');
        ticksG.appendChild(c);
      });
      midLabel.textContent = mode==='snap' ? 'the other 364 days' : 'drift corrected within days';
    }
    function posture(t){
      if(mode==='snap'){
        const sag=(yLow-yReq)*Math.sin(Math.PI*t);
        return yReq+sag*(0.75+0.25*Math.sin(7*t));
      }
      const drift=14*Math.abs(Math.sin(9*Math.PI*t));
      const correct=Math.pow(Math.sin(9*Math.PI*t),8)*10;
      return yReq+6+drift-correct;
    }
    function run(){
      if(anim)cancelAnimationFrame(anim);
      const T=3200;let start=null;
      dot.setAttribute('opacity','1');
      function frame(ts){
        if(!start)start=ts;
        const p=Math.min((ts-start)/T,1);
        let d='';
        const steps=Math.max(2,Math.floor(140*p));
        for(let i=0;i<=steps;i++){
          const t=(i/140), x=x0+(x1-x0)*t, y=posture(t);
          d+=(i?' L':'M')+x.toFixed(1)+' '+y.toFixed(1);
        }
        line.setAttribute('d',d);
        const xN=x0+(x1-x0)*p, yN=posture(p);
        dot.setAttribute('cx',xN);dot.setAttribute('cy',yN);
        if(p<1)anim=requestAnimationFrame(frame);
      }
      anim=requestAnimationFrame(frame);
    }
    function setMode(m){
      mode=m;
      snapBtn.classList.toggle('active',m==='snap');
      liveBtn.classList.toggle('active',m==='live');
      line.setAttribute('d','');dot.setAttribute('opacity','0');
      drawTicks();
    }
    snapBtn.onclick=()=>setMode('snap');
    liveBtn.onclick=()=>setMode('live');
    runBtn.onclick=run;
    drawTicks();
  })();

  /* ---------- Fig. 6: Ladder ---------- */
  (function(){
    const details=[
      {ttl:"01 · Wedge — “You will be audit-ready.”",
       txt:"Sell the outcome at a fraction of the $50–150k consulting engagement it replaces. The buyer is the CEO or CTO with a deal on the line — not a compliance professional. The pitch is “close your next deal faster,” delivered in weeks, not quarters."},
      {ttl:"02 · Expand — “Your second framework costs 60% less.”",
       txt:"The system already knows the stack, the policies, the evidence chain. ISO 27001, HIPAA, CMMC — whatever the next deal requires. Because that groundwork is already done, each new framework starts from what is already in place, not from scratch."},
      {ttl:"03 · Platform — “Your compliance runs.”",
       txt:"Continuous monitoring, automated evidence, audit-ready at all times — the $150–250k/year insourced compliance function, absorbed into infrastructure. Different buyer, different budget, and unit economics that improve with every engagement."}
    ];
    const detail=document.getElementById('rungDetail');
    const rungs=[...document.querySelectorAll('.manifesto .rung')];
    if(!detail || !rungs.length){ console.warn('[fig6] missing element — figure not initialized'); return; }
    function show(i){
      rungs.forEach((r,j)=>r.classList.toggle('active',i===j));
      detail.innerHTML='<span class="ttl">'+details[i].ttl+'</span>'+details[i].txt;
    }
    rungs.forEach(r=>r.onclick=()=>show(+r.dataset.i));
    show(0);
  })();
  </script>

  <style is:global>
  /* Manifesto essay — ported from the standalone HTML draft, scoped under
     .manifesto. is:global because the SVG figures are built by client scripts
     (createElementNS), which Astro's scoped-style hashing would not reach.
     Token values are kept literal: they already equal the brand tokens. */
  .manifesto{
    --paper:#F6F2EA;
    --paper-deep:#EFE9DC;
    --ink:#1A1614;
    --ink-soft:#44372F;
    --accent:#4A2F22;
    --gold:#B08A4E;
    --line:#D9D0BF;
    --line-soft:rgba(26,22,20,.12);
    --serif:"Newsreader",Georgia,"Times New Roman",serif;
    --sans:"IBM Plex Sans",system-ui,-apple-system,sans-serif;
    --mono:"IBM Plex Mono","SFMono-Regular",ui-monospace,monospace;
    background:var(--paper);
    color:var(--ink-soft);
    font-family:var(--sans);
    font-size:17px;
    line-height:1.62;
    font-weight:400;
    -webkit-font-smoothing:antialiased;
  }
  .manifesto *{margin:0;padding:0;box-sizing:border-box}
  .manifesto p b{color:var(--ink);font-weight:600}
  .manifesto .spine{
    position:fixed;left:14px;top:50%;transform:translateY(-50%);
    writing-mode:vertical-rl;text-orientation:mixed;
    font-family:var(--mono);font-size:10px;letter-spacing:.35em;
    color:var(--ink-soft);opacity:.55;user-select:none;
  }
  @media(max-width:900px){.manifesto .spine{display:none}}
  .manifesto .page{max-width:700px;margin:0 auto;padding:0 24px 120px}
  .manifesto header.masthead{padding:72px 0 24px}
  .manifesto .kicker{
    display:flex;justify-content:space-between;align-items:baseline;
    font-family:var(--mono);font-size:11px;letter-spacing:.22em;
    color:var(--ink-soft);text-transform:uppercase;margin-bottom:40px;
  }
  .manifesto .kicker .co{color:var(--accent)}
  .manifesto h1{
    font-family:var(--serif);color:var(--ink);
    font-size:56px;line-height:1.04;font-weight:400;font-style:normal;
    letter-spacing:-.028em;margin-bottom:28px;
  }
  .manifesto h1 em{font-style:italic;color:var(--accent)}
  @media(max-width:600px){.manifesto h1{font-size:38px}}
  .manifesto .deck{font-family:var(--serif);font-size:22px;line-height:1.42;color:var(--ink-soft);font-style:normal;max-width:560px}
  .manifesto .deck b{color:var(--ink);font-style:normal;font-weight:500}
