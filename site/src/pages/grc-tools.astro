---
// The GRC tools index — an evergreen, SEO/GEO-friendly directory of the
// compliance tooling we track. Structure borrowed from terminalvalue.io
// (status line, scannable rows, price tags, category + A→Z grouping) but
// styled in the Eagle Ridge brand so it reads as a sibling of /market-map.
//
// Data comes from src/data/grc-tools.json via the grcTools content collection
// (Zod-validated — bad data fails the build). The rows, FAQ, and notes are
// server-rendered so they land in the .md mirror (the LLM-ingestion surface);
// only the interactive controls carry data-md-exclude.
//
// PARITY: never put a system-clock date in rendered copy — the .md mirror must
// be byte-stable. "Updated" is derived from the data's newest lastReviewed.
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

type Tool = {
  id: string;
  name: string;
  type: string;
  priceTag: string;
  blurb: string;
  frameworks: string[];
  market: string;
  website: string;
  lastReviewed: string;
  published: boolean;
};

const TYPE_ORDER = [
  'Compliance automation',
  'Enterprise GRC',
  'CMMC-native',
  'Data protection',
  'Third-party risk',
  'Privacy management',
  'Open-source GRC',
];
const PRICE_ORDER: Record<string, number> = { FREE: 0, $: 1, $$: 2, $$$: 3, 'N/A': 4 };
const PRICE_HINT: Record<string, string> = {
  FREE: 'Free or open-source',
  $: 'Entry-level pricing',
  $$: 'Mid pricing',
  $$$: 'Enterprise pricing',
  'N/A': 'Pricing not published',
};
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

const tools = (await getCollection('grcTools'))
  .map((e) => ({ id: e.id, ...e.data }) as Tool)
  .filter((t) => t.published);

// Default display order = category order (TYPE_ORDER), then name. This is the
// order the .md mirror captures; the client script re-sorts at runtime only.
const byType = (t: Tool) => {
  const i = TYPE_ORDER.indexOf(t.type);
  return i === -1 ? TYPE_ORDER.length : i;
};
tools.sort((a, b) => byType(a) - byType(b) || a.name.localeCompare(b.name));

const total = tools.length;
const updated = tools.reduce((max, t) => (t.lastReviewed > max ? t.lastReviewed : max), '0000-00-00');
const [uY, uM] = updated.split('-');
const updatedLabel = `${MONTHS[Number(uM) - 1]} ${uY}`;

const typeCounts = TYPE_ORDER.map((type) => ({
  type,
  count: tools.filter((t) => t.type === type).length,
})).filter((x) => x.count > 0);

const azTools = [...tools].sort((a, b) => a.name.localeCompare(b.name));

const faqs = [
  {
    q: 'What is the best GRC tool for CMMC compliance?',
    a: 'For CMMC specifically, look at CMMC-native tools like FutureFeed, Totem, and IntelliGRC, or compliance-automation platforms with real CMMC coverage such as Hyperproof and Apptega. But remember a tool documents your work; it does not do the readiness. Eagle Ridge gets defense-industrial-base small businesses ready to pass — gaps found, fixed, and an SSP and SPRS score produced — before an assessor grades you.',
  },
  {
    q: 'What are the cheapest or open-source GRC tools?',
    a: 'Open-source options include CISO Assistant and eramba, both free to self-host, and SimpleRisk offers a free community edition. For freemium SaaS, TrustCloud has a free tier. Budget commercial automation generally starts with Sprinto and Scrut.',
  },
  {
    q: 'Vanta vs Drata — which is better?',
    a: 'Both are category-leading compliance-automation platforms. Vanta leads on SOC 2 breadth and ecosystem; Drata has a stronger FedRAMP story and growing CMMC coverage. Both are SaaS-first and lighter on DIB-native CMMC readiness than the CMMC-native tools.',
  },
  {
    q: 'Which GRC tools support CMMC and NIST 800-171?',
    a: 'Tools with CMMC / NIST 800-171 coverage in this index include FutureFeed, Totem, Cyturus, IntelliGRC, Paramify, Exostar, Apptega, Hyperproof, Drata, Scrut, and Risk Cognizance.',
  },
  {
    q: 'Do I need a GRC tool to pass CMMC?',
    a: 'No. A tool helps you track and document controls, but it will not close gaps, write your System Security Plan, or submit your SPRS score for you. Tooling is optional; readiness is not — and readiness is the work Eagle Ridge does.',
  },
];

const title = 'GRC & compliance tools index | Eagle Ridge Advisory';
const description = `An independent, regularly reviewed index of ${total} GRC and compliance tools — compliance automation, enterprise GRC, CMMC-native, data protection, third-party risk, and privacy — with pricing, frameworks, and where each fits.`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  url: 'https://eagleridge.io/grc-tools',
  description,
  isPartOf: { '@type': 'WebSite', name: 'Eagle Ridge Advisory', url: 'https://eagleridge.io/' },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: total,
    itemListElement: tools.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'SoftwareApplication',
        name: t.name,
        url: t.website,
        applicationCategory: t.type,
        description: t.blurb,
      },
    })),
  },
});

const faqLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

<BaseLayout title={title} description={description} path="/grc-tools" ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
    <script type="application/ld+json" set:html={faqLd} />
    <meta property="og:image" content="https://eagleridge.io/logo.png" />
  </Fragment>

  <div class="grc-index">
    <div class="wrap">
      <header class="page">
        <h1>GRC &amp; compliance tools — the complete index</h1>
        <p class="status">Manually reviewed &middot; {total} tools indexed &middot; updated {updatedLabel}</p>
      </header>

      <section class="lead">
        <p class="first-line">Every GRC and compliance tool we track, in one place — what it is, who it is for, and what it roughly costs.</p>
        <p>Software helps you track and document controls. It does not, by itself, get you ready. We keep this index because the tooling market is noisy and small teams need a plain-language map of it. Firms, assessors, and authorities are not tools — they live on the <a href="/market-map">CMMC market map</a>.</p>
      </section>

      <div class="controls" data-md-exclude>
        <input type="text" id="search" placeholder="Search by name, category, or framework..." aria-label="Search tools" />
        <button id="reset" type="button">Reset</button>
      </div>

      <div class="sortbar" data-md-exclude>
        <span class="sort-label">Sort</span>
        <button type="button" class="sort-btn is-active" data-sort="category">Category</button>
        <button type="button" class="sort-btn" data-sort="name">A→Z</button>
        <button type="button" class="sort-btn" data-sort="price">Price</button>
        <button type="button" class="sort-btn" data-sort="reviewed">Newest</button>
      </div>

      <div class="legend" id="legend" data-md-exclude>
        {typeCounts.map(({ type, count }) => (
          <button type="button" class="legend-item" aria-pressed="false" data-type={type}>
            {type} <span class="legend-count">{count}</span>
          </button>
        ))}
      </div>

      <ol class="tool-list" id="tool-list">
        {tools.map((t) => (
          <li
            class="tool-row"
            data-type={t.type}
            data-price={PRICE_ORDER[t.priceTag]}
            data-reviewed={t.lastReviewed}
            data-name={t.name.toLowerCase()}
            data-search={`${t.name} ${t.type} ${t.market} ${t.frameworks.join(' ')} ${t.blurb}`.toLowerCase()}
          >
            <span class="rank" aria-hidden="true"></span>
            <div class="row-main">
              <p class="row-head">
                <a class="tool-name" href={t.website} target="_blank" rel="noopener nofollow">
                  {t.name}<span class="ext" aria-hidden="true">↗</span>
                </a>
                <span class="tool-type">{t.type}</span>
              </p>
              <p class="row-blurb">{t.blurb}</p>
              <p class="row-tags">
                <span class="tag market">{t.market}</span>{' '}
                {t.frameworks.map((f) => (<><span class="tag fw">{f}</span>{' '}</>))}
              </p>
            </div>
            <span class={`price price-${PRICE_ORDER[t.priceTag]}`} title={PRICE_HINT[t.priceTag]}>{t.priceTag}</span>
          </li>
        ))}
      </ol>

      <section class="browse">
        <h2>Browse by category</h2>
        <ul class="cat-summary">
          {typeCounts.map(({ type, count }) => (
            <li><strong>{type}</strong> — {count} {count === 1 ? 'tool' : 'tools'}</li>
          ))}
        </ul>
      </section>

      <section class="az">
        <h2>All tools, A→Z</h2>
        <p class="az-list">
          {azTools.map((t, i) => (
            <>{i > 0 ? ' · ' : ''}<a href={t.website} target="_blank" rel="noopener nofollow">{t.name}</a></>
          ))}
        </p>
      </section>

      <section class="faq">
        <h2>Frequently asked questions</h2>
        {faqs.map((f) => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </section>

      <section class="methodology">
        <h2>How we keep this list</h2>
        <p>We index software tools and platforms — compliance automation, enterprise GRC, CMMC-native tooling, data protection, third-party risk, and privacy. Consulting firms, C3PAOs, MSSPs, and standards bodies are not tools; they sit on the <a href="/market-map">CMMC market map</a> instead. Pricing tiers (FREE, $, $$, $$$) are directional, not quotes. Each entry shows when we last reviewed it; the list is refreshed on a rolling basis. Spotted something wrong or missing? Tell us at <a href="mailto:contact@eagleridge.io">contact@eagleridge.io</a>.</p>
        <p>Our point of view: tooling documents readiness, it does not produce it. The gap most small defense contractors hit is the work between "we bought a tool" and "we can pass an assessment." For the longer argument, read <a href="/nobody-built-the-first-mile">Nobody Built the First Mile</a>.</p>
      </section>

      <div class="cta">
        <p><strong>Need to actually be ready, not just tooled up?</strong> Eagle Ridge takes small businesses through the whole CMMC readiness lifecycle — gaps found, fixed, and documented, with your SSP and SPRS score in hand — so you are prepared before you are assessed.</p>
        <p>Write to <a href="mailto:contact@eagleridge.io">contact@eagleridge.io</a> or <a href="/#contact-form">start a conversation</a>.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* GRC tools index — Eagle Ridge brand (tokens.css). Hairline rules over
     boxes, serif headings, mono for data/labels. Sibling of .map-body. */
  .grc-index { font-size: 15px; line-height: 1.55; }
  .grc-index .wrap { max-width: 880px; margin: 0 auto; padding: 32px 24px 64px; }

  .grc-index header.page { padding: 0 0 24px; margin-bottom: 28px; border-bottom: 1px solid var(--er-rule); }
  .grc-index header.page h1 { font-size: var(--er-text-h1); font-weight: 400; margin: 0 0 8px; letter-spacing: var(--er-tracking-tight); }
  .grc-index header.page p.status { margin: 12px 0 0; font-family: var(--er-font-mono); font-size: 12px; color: var(--er-mute); letter-spacing: 0.02em; }

  .grc-index section.lead { margin: 0 0 28px; }
  .grc-index section.lead p { margin: 0 0 12px; font-size: 15px; line-height: 1.65; color: var(--er-ink-soft); }
  .grc-index section.lead p.first-line { font-weight: 300; font-size: var(--er-text-lede); color: var(--er-ink); line-height: 1.5; }
  .grc-index a { color: var(--er-accent); text-decoration: none; }
  .grc-index a:hover { text-decoration: underline; }

  .grc-index .controls { display: flex; gap: 10px; margin: 0 0 12px; align-items: center; flex-wrap: wrap; }
  .grc-index .controls input[type="text"] {
    flex: 1; min-width: 200px; height: 38px; padding: 0 12px;
    border: var(--er-border); border-radius: var(--er-radius-md);
    font-family: var(--er-font-sans); font-size: 14px; color: var(--er-ink); background: var(--er-paper);
  }
  .grc-index .controls input[type="text"]:focus { outline: none; border-color: var(--er-accent); box-shadow: 0 0 0 2px rgba(74, 47, 34, 0.12); }
  .grc-index .controls button, .grc-index .sort-btn {
    height: 34px; padding: 0 14px;
    border: var(--er-border); border-radius: var(--er-radius-md);
    background: var(--er-paper); color: var(--er-ink-soft);
    font-family: var(--er-font-mono); font-size: 12px; letter-spacing: 0.04em;
    cursor: pointer;
  }
  .grc-index .controls button:hover, .grc-index .sort-btn:hover { background: var(--er-bg); }
  .grc-index .sortbar { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin: 0 0 14px; }
  .grc-index .sort-label { font-family: var(--er-font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--er-mute); margin-right: 2px; }
  .grc-index .sort-btn.is-active { background: var(--er-accent); color: var(--er-bg); border-color: var(--er-accent); }

  .grc-index .legend { display: flex; flex-wrap: wrap; gap: 6px; margin: 0 0 20px; }
  .grc-index .legend-item {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 5px 10px; border-radius: var(--er-radius-md); cursor: pointer;
    border: var(--er-border); background: var(--er-paper);
    color: var(--er-ink-soft); font-family: var(--er-font-mono); font-size: 11.5px;
    letter-spacing: 0.02em; transition: opacity 0.15s ease;
  }
  .grc-index .legend-item:hover { border-color: var(--er-mute); }
  .grc-index .legend-item:focus-visible { outline: 2px solid var(--er-accent); outline-offset: 2px; }
  .grc-index .legend-item.dim { opacity: 0.35; }
  .grc-index .legend-item[aria-pressed="true"] { border-color: var(--er-accent); color: var(--er-ink); }
  .grc-index .legend-count { color: var(--er-mute); }

  .grc-index .tool-list { list-style: none; margin: 0; padding: 0; counter-reset: row; border-top: 1px solid var(--er-rule); }
  .grc-index .tool-row {
    counter-increment: row;
    display: grid; grid-template-columns: 2.2rem 1fr auto; gap: 14px; align-items: start;
    padding: 16px 4px; border-bottom: 1px solid var(--er-rule);
  }
  .grc-index .tool-row.is-hidden { display: none; }
  .grc-index .tool-row .rank { font-family: var(--er-font-mono); font-size: 12px; color: var(--er-mute); padding-top: 3px; }
  .grc-index .tool-row .rank::before { content: counter(row, decimal-leading-zero); }
  .grc-index .row-head { margin: 0 0 5px; display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px; }
  .grc-index .tool-name { font-family: var(--er-font-serif); font-size: 19px; color: var(--er-ink); font-weight: 400; }
  .grc-index .tool-name:hover { color: var(--er-accent); text-decoration: none; }
  .grc-index .tool-name .ext { font-family: var(--er-font-mono); font-size: 12px; color: var(--er-mute); margin-left: 4px; }
  .grc-index .tool-type { font-family: var(--er-font-sans); font-size: var(--er-text-eyebrow); text-transform: uppercase; letter-spacing: var(--er-tracking-eyebrow); color: var(--er-accent); }
  .grc-index .row-blurb { margin: 0 0 8px; font-size: 14px; line-height: 1.6; color: var(--er-ink-soft); }
  .grc-index .row-tags { margin: 0; display: flex; flex-wrap: wrap; gap: 5px; }
  .grc-index .tag {
    font-family: var(--er-font-mono); font-size: 10.5px; letter-spacing: 0.02em;
    padding: 2px 7px; border-radius: var(--er-radius-sm);
    border: 1px solid var(--er-rule); color: var(--er-mute); background: var(--er-bg);
  }
  .grc-index .tag.market { color: var(--er-ink-soft); border-color: var(--er-mute); }
  .grc-index .price {
    font-family: var(--er-font-mono); font-weight: 500; font-size: 13px;
    padding: 3px 9px; border-radius: var(--er-radius-sm); white-space: nowrap;
    border: 1px solid var(--er-rule); align-self: start;
  }
  .grc-index .price-0 { color: #27500A; background: #EAF3DE; border-color: #639922; } /* FREE */
  .grc-index .price-1 { color: var(--er-ink-soft); background: var(--er-paper); }
  .grc-index .price-2 { color: var(--er-accent); background: var(--er-paper); }
  .grc-index .price-3 { color: #633806; background: #FAEEDA; border-color: #BA7517; }

  .grc-index section.browse, .grc-index section.az, .grc-index section.faq, .grc-index section.methodology {
    margin: 40px 0 0; padding: 24px 0 0; border-top: 1px solid var(--er-rule);
  }
  .grc-index h2 { font-size: var(--er-text-h3); font-weight: 400; margin: 0 0 14px; }
  .grc-index .cat-summary { margin: 0; padding-left: 20px; }
  .grc-index .cat-summary li { margin-bottom: 6px; color: var(--er-ink-soft); }
  .grc-index .az-list { line-height: 2; font-size: 14px; color: var(--er-ink-soft); }
  .grc-index .faq-item { margin-bottom: 18px; }
  .grc-index .faq-item h3 { font-family: var(--er-font-serif); font-size: 17px; font-weight: 400; color: var(--er-ink); margin: 0 0 6px; }
  .grc-index .faq-item p { margin: 0; font-size: 14px; line-height: 1.65; color: var(--er-ink-soft); }
  .grc-index section.methodology p { margin: 0 0 12px; color: var(--er-ink-soft); line-height: 1.65; }

  .grc-index .cta { padding: 20px 0; margin: 32px 0 0; border-top: 1px solid var(--er-rule); border-bottom: 1px solid var(--er-rule); }
  .grc-index .cta p { margin: 0 0 10px; font-size: 15px; line-height: 1.65; color: var(--er-ink-soft); }
  .grc-index .cta p:last-child { margin-bottom: 0; }

  @media (max-width: 720px) {
    .grc-index .wrap { padding: 20px 14px 40px; }
    .grc-index .tool-row { grid-template-columns: 1.6rem 1fr; }
    .grc-index .tool-row .price { grid-column: 2; justify-self: start; margin-top: 2px; }
  }
</style>

<script>
  // Interactivity island: search, sort, and category filter over the
  // server-rendered list. The list's build-time order (category, then name) is
  // what the .md mirror captures; this only reorders/filters at runtime.
  const list = document.getElementById('tool-list');
  const search = document.getElementById('search') as HTMLInputElement | null;
  const reset = document.getElementById('reset');
  const legend = document.getElementById('legend');
  const sortbar = document.querySelector('.sortbar');

  if (list && search && reset && legend && sortbar) {
    const rows = Array.from(list.querySelectorAll<HTMLLIElement>('.tool-row'));
    const legendItems = Array.from(legend.querySelectorAll<HTMLButtonElement>('.legend-item'));
    const sortBtns = Array.from(sortbar.querySelectorAll<HTMLButtonElement>('.sort-btn'));
    let activeType: string | null = null;

    const num = (r: HTMLElement, k: string) => Number(r.dataset[k] ?? 0);
    const str = (r: HTMLElement, k: string) => r.dataset[k] ?? '';

    function applyFilters() {
      const q = search!.value.trim().toLowerCase();
      rows.forEach((r) => {
        const typeHit = !activeType || r.dataset.type === activeType;
        const searchHit = !q || str(r, 'search').includes(q);
        r.classList.toggle('is-hidden', !(typeHit && searchHit));
      });
    }

    function sortBy(mode: string) {
      const sorted = [...rows].sort((a, b) => {
        if (mode === 'name') return str(a, 'name').localeCompare(str(b, 'name'));
        if (mode === 'price') return num(a, 'price') - num(b, 'price') || str(a, 'name').localeCompare(str(b, 'name'));
        if (mode === 'reviewed') return str(b, 'reviewed').localeCompare(str(a, 'reviewed')) || str(a, 'name').localeCompare(str(b, 'name'));
        // category = original DOM order
        return rows.indexOf(a) - rows.indexOf(b);
      });
      sorted.forEach((r) => list!.appendChild(r));
    }

    search.addEventListener('input', applyFilters);

    legendItems.forEach((li) => {
      li.addEventListener('click', () => {
        const t = li.dataset.type ?? null;
        activeType = activeType === t ? null : t;
        legendItems.forEach((x) => {
          const on = x.dataset.type === activeType;
          x.classList.toggle('dim', activeType !== null && !on);
          x.setAttribute('aria-pressed', String(on));
        });
        applyFilters();
      });
    });

    sortBtns.forEach((b) => {
      b.addEventListener('click', () => {
        sortBtns.forEach((x) => x.classList.toggle('is-active', x === b));
        sortBy(b.dataset.sort ?? 'category');
      });
    });

    reset.addEventListener('click', () => {
      search!.value = '';
      activeType = null;
      legendItems.forEach((x) => {
        x.classList.remove('dim');
        x.setAttribute('aria-pressed', 'false');
      });
      sortBtns.forEach((x) => x.classList.toggle('is-active', x.dataset.sort === 'category'));
      sortBy('category');
      applyFilters();
    });
  }
</script>
